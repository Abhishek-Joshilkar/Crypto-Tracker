# Copy this file to .env and add your CoinGecko API key.
# Get a free Demo key: https://www.coingecko.com/en/api

VITE_COINGECKO_API_KEY=your_api_key_here

# Use "demo" (default) for the free Demo API, or "pro" for a paid Pro plan.
VITE_COINGECKO_API_PLAN=demo

# Supabase Auth (Step 1) — https://supabase.com/dashboard
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
